# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# runtime logs
logs/
*.log

# runtime settings (rewritten by the app); keep settings.example/
settings/

# dist build output (scripts under dist/ are tracked)
dist/phantom-exporter
dist/phantom-exporter-amd64
dist/logs/
dist/settings/
dist/web/
dist/*.pid
dist/phantom-exporter.env

# Editor/IDE
# .idea/
# .vscode/

.vscode/launch.json